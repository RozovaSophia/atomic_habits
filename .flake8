[flake8]
max-line-length = 120
exclude =
    .git,
    __pycache__,
    .venv,
    venv,
    env,
    ENV,
    .env,
    .tox,
    .pytest_cache,
    .mypy_cache,
    .coverage,
    htmlcov,
    dist,
    build,
    *.egg-info,
    .idea,
    .vscode,
    node_modules,
    migrations,
    */migrations/*,
    static,
    media,
    staticfiles,
    .github
ignore =
    E122, E123, E125, E126, E127, E128,
    E203, E261, E265, E266, E302, E305,
    E402, E501, E713, F401, F403, F405,
    F541, F811, F821, W291, W293, W503
max-complexity = 10
max-args = 6
max-locals = 15
max-returns = 6
max-statements = 50
max-branches = 12
format = pylint
statistics = True
count = True